---
import { u } from '../lib/urls';

const { placeholder = 'Search every transcript…' } = Astro.props;
const css = u('/pagefind/pagefind-ui.css');
const js = u('/pagefind/pagefind-ui.js');
---
<div class="search-shell">
  <link href={css} rel="stylesheet" />
  <div id="search"></div>
  <script is:inline src={js}></script>
  <script is:inline define:vars={{ placeholder }}>
    window.addEventListener('DOMContentLoaded', () => {
      const el = document.getElementById('search');
      if (typeof PagefindUI === 'undefined') {
        el.innerHTML =
          '<p style="color:var(--muted);font-size:0.85rem;">Search index is generated by the production build (npm run build).</p>';
        return;
      }
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        resetStyles: false,
        translations: { placeholder },
      });
    });
  </script>
</div>
