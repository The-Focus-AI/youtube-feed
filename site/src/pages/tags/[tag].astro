---
import Base from '../../layouts/Base.astro';
import VideoCard from '../../components/VideoCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  const byTag = new Map<string, typeof videos>();
  for (const v of videos) {
    for (const t of v.data.tags) {
      if (!byTag.has(t)) byTag.set(t, []);
      byTag.get(t)!.push(v);
    }
  }
  return [...byTag.entries()].map(([tag, vids]) => ({
    params: { tag },
    props: {
      tag,
      videos: vids.sort(
        (a, b) => (b.data.upload_date?.getTime() ?? 0) - (a.data.upload_date?.getTime() ?? 0),
      ),
    },
  }));
}

const { tag, videos } = Astro.props;
---
<Base title={`#${tag} — Archive`}>
  <section class="page-title">
    <h1>#{tag}</h1>
    <p style="color:var(--muted);">{videos.length} video{videos.length === 1 ? '' : 's'}</p>
  </section>
  <div class="grid">
    {videos.map((v) => <VideoCard entry={v} showTags={false} />)}
  </div>
</Base>
