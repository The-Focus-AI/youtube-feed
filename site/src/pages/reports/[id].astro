---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { u, fmtDate } from '../../lib/urls';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const m = entry.body?.match(/^#\s+(.+)$/m);
const title = entry.data.title ?? (m ? m[1] : entry.id);
---
<Base title={`${title} — Reports`} description={entry.data.description}>
  <article class="article" data-pagefind-body data-pagefind-filter="type:Report">
    <div class="hd">
      <a class="back" href={u('/reports/')}>← Reports</a>
      <h1 data-pagefind-meta="title">{title}</h1>
      {entry.data.date && (
        <div class="meta"><span>{fmtDate(entry.data.date)}</span></div>
      )}
    </div>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
