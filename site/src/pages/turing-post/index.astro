---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { u, videoPath, tagPath, fmtViews, fmtDate } from '../../lib/urls';

const videos = (await getCollection('videos')).sort(
  (a, b) => (b.data.upload_date?.getTime() ?? 0) - (a.data.upload_date?.getTime() ?? 0),
);
const totalViews = videos.reduce((s, v) => s + (v.data.view_count ?? 0), 0);
const pagefindCss = u('/pagefind/pagefind-ui.css');
const pagefindJs = u('/pagefind/pagefind-ui.js');
---
<Base title="Turing Post — Archive" description="Turing Post video transcripts and summaries.">
  <section class="channel-head">
    <h1>Turing Post</h1>
    <p class="sub">@RealTuringPost · AI/ML deep dives and industry interviews</p>
    <div class="stats">
      <div class="stat"><div class="n">{videos.length}</div><div class="l">Videos</div></div>
      <div class="stat"><div class="n">{fmtViews(totalViews)}</div><div class="l">Total views</div></div>
    </div>
  </section>

  <div class="search-shell">
    <link href={pagefindCss} rel="stylesheet" />
    <div id="search"></div>
    <script is:inline src={pagefindJs}></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof PagefindUI === 'undefined') {
          document.getElementById('search').innerHTML =
            '<p style="color:var(--muted);font-size:0.85rem;">Search index is generated by the production build (npm run build).</p>';
          return;
        }
        new PagefindUI({ element: '#search', showSubResults: true, resetStyles: false });
      });
    </script>
  </div>

  <div class="grid">
    {videos.map((v) => (
      <div class="card">
        <a class="thumb" href={videoPath(v.data.video_id)}>
          <img src={v.data.thumbnail} alt={v.data.title} loading="lazy" />
        </a>
        <div class="body">
          <h3><a href={videoPath(v.data.video_id)}>{v.data.title}</a></h3>
          <div class="chips">
            {v.data.tags.slice(0, 4).map((t) => (
              <a class="chip" href={tagPath(t)}>{t}</a>
            ))}
          </div>
          <div class="row">
            <span class="dur">{v.data.duration_formatted}</span>
            <span>{fmtViews(v.data.view_count)} views</span>
            <span>{fmtDate(v.data.upload_date)}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</Base>
